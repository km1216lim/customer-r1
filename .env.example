# Copy this file to `.env` (which is gitignored) and fill in your secrets.
# Load in shell: `set -a; source .env; set +a`
# Or in Python: `from dotenv import load_dotenv; load_dotenv()`
#
# DO NOT commit `.env` — it is in `.gitignore`.

# Google AI Studio (used by Phase E synthesize_rationales.py for Gemini)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — Hugging Face token for higher rate limits on dataset/tokenizer downloads
# Get a read-token at https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional — Anthropic API (if you ever swap Gemini for Claude rationale synthesis)
ANTHROPIC_API_KEY=

# Optional — Weights & Biases run logging (train/sft.py, train/grpo.py)
WANDB_API_KEY=
