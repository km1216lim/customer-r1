# Copy this file to `.env` (which is gitignored) and fill in your secrets.
# Load in shell: `set -a; source .env; set +a`
# Or in Python: `from dotenv import load_dotenv; load_dotenv()`
#
# DO NOT commit `.env` — it is in `.gitignore`.

# --- Vertex AI Gemini 2.5 Pro (data/synthesize_rationales.py, Phase E) ---
# Service-account JSON key path with the "Vertex AI User" role on the project.
# The key file itself is gitignored via .gcp/, gcp-*.json, service-account*.json patterns.
GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/service-account.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Legacy / fallback — Google AI Studio API key (not used for current synthesis pipeline)
# Only needed if you ever flip synthesize_rationales.py back to API-key auth.
GEMINI_API_KEY=

# Optional — Hugging Face token for higher rate limits on dataset/tokenizer downloads
# Get a read-token at https://huggingface.co/settings/tokens
HF_TOKEN=

# Optional — Anthropic API (if you ever swap Gemini for Claude rationale synthesis)
ANTHROPIC_API_KEY=

# Optional — Weights & Biases run logging (train/sft.py, train/grpo.py)
WANDB_API_KEY=
